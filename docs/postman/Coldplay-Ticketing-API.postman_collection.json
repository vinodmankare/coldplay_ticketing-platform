    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /api/v1/bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.booking_id) {",
                  "    pm.environment.set('booking_id', body.booking_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotency_key}}",
                "type": "text"
              },
              {
                "key": "Origin",
                "value": "{{origin}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": {{event_id}},\n  \"user_name\": \"Vinod\",\n  \"user_email\": \"vinod@example.com\",\n  \"ticket_count\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/bookings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "bookings"
              ]
            }
          }
        },
        {
          "name": "GET /api/v1/bookings/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/bookings/{{booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "bookings",
                "{{booking_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
