DB_PATH=/var/www/backend/storage/app.sqlite
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TOKEN=local-dev-csrf-token
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_PER_IP=25
RATE_LIMIT_GLOBAL_MAX=500
MAIL_TRANSPORT=log
MAIL_FROM=no-reply@coldplay.local
WORKER_BATCH_SIZE=100
WORKER_IDLE_SLEEP_SECONDS=2
WORKER_BUSY_SLEEP_SECONDS=1
